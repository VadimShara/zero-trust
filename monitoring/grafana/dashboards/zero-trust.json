{
  "title": "Zero Trust Auth",
  "uid": "zero-trust",
  "schemaVersion": 38,
  "refresh": "10s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Logins (total)",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "targets": [{"expr": "sum(gateway_login_total)", "legendFormat": "total"}],
      "options": {"colorMode": "value", "graphMode": "area"}
    },
    {
      "id": 2, "type": "stat", "title": "Token Exchanges",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "targets": [{"expr": "sum(gateway_token_exchange_total{result='success'})", "legendFormat": "success"}],
      "options": {"colorMode": "value", "graphMode": "area"}
    },
    {
      "id": 3, "type": "stat", "title": "Forced Logouts",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "targets": [{"expr": "token_forced_logout_total", "legendFormat": "total"}],
      "fieldConfig": {"defaults": {"color": {"mode": "fixed", "fixedColor": "red"}}},
      "options": {"colorMode": "value", "graphMode": "area"}
    },
    {
      "id": 4, "type": "stat", "title": "Token Reuse Attacks",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "targets": [{"expr": "sum(token_refresh_total{result='reuse_attack'})", "legendFormat": "attacks"}],
      "fieldConfig": {"defaults": {"color": {"mode": "fixed", "fixedColor": "dark-red"}}},
      "options": {"colorMode": "value", "graphMode": "area"}
    },
    {
      "id": 5, "type": "stat", "title": "MFA Success Rate",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "targets": [{"expr": "sum(gateway_mfa_total{result='success'}) / sum(gateway_mfa_total) * 100", "legendFormat": "%"}],
      "options": {"colorMode": "value", "graphMode": "none"},
      "fieldConfig": {"defaults": {"unit": "percent"}}
    },
    {
      "id": 6, "type": "stat", "title": "Active Introspects/s",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "targets": [{"expr": "rate(token_introspect_total{result='active'}[1m])", "legendFormat": "active/s"}],
      "options": {"colorMode": "value", "graphMode": "area"}
    },
    {
      "id": 7, "type": "timeseries", "title": "Login Flow — Decisions per minute",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {"expr": "rate(gateway_login_total[1m]) * 60", "legendFormat": "{{decision}}"}
      ]
    },
    {
      "id": 8, "type": "timeseries", "title": "Token Operations per minute",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {"expr": "rate(token_issue_total[1m]) * 60", "legendFormat": "issue"},
        {"expr": "rate(token_refresh_total{result='success'}[1m]) * 60", "legendFormat": "refresh"},
        {"expr": "rate(token_refresh_total{result='reuse_attack'}[1m]) * 60", "legendFormat": "reuse_attack"},
        {"expr": "rate(token_forced_logout_total[1m]) * 60", "legendFormat": "forced_logout"}
      ]
    },
    {
      "id": 9, "type": "heatmap", "title": "Trust Score Distribution",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {"expr": "sum(rate(token_introspect_trust_score_bucket[5m])) by (le)", "legendFormat": "{{le}}"}
      ],
      "options": {"calculate": false, "yAxis": {"unit": "short"}},
      "fieldConfig": {"defaults": {"color": {"mode": "scheme", "scheme": "Spectral"}}}
    },
    {
      "id": 10, "type": "timeseries", "title": "API Requests by Result",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {"expr": "rate(gateway_api_requests_total{result='allowed'}[1m]) * 60", "legendFormat": "allowed"},
        {"expr": "rate(gateway_api_requests_total{result='forbidden'}[1m]) * 60", "legendFormat": "forbidden"},
        {"expr": "rate(gateway_api_requests_total{result='insufficient_trust'}[1m]) * 60", "legendFormat": "step-up"}
      ]
    },
    {
      "id": 11, "type": "timeseries", "title": "Introspect Results per minute",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "targets": [
        {"expr": "rate(token_introspect_total[1m]) * 60", "legendFormat": "{{result}}"}
      ]
    },
    {
      "id": 12, "type": "timeseries", "title": "Step-up Challenges by Resource",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "targets": [
        {"expr": "rate(gateway_step_up_challenges_total[1m]) * 60", "legendFormat": "{{resource}}"}
      ]
    }
  ]
}

' ============================================================
' TRUST
' ============================================================
package "trust" #FAEEF5 {

  package "trust::entities" {
    class RiskSignal {
      +Name: string
      +Score: float64
      +Weight: float64
    }
    class "trust::TrustContext" as TrustCtxEntity {
      +UserID: uuid.UUID
      +IPHash: string
      +Country: string
      +ASN: string
      +UserAgent: string
      +FingerprintHash: string
      +Timestamp: time.Time
    }
    class TrustScore {
      +Value: float64
      +Decision: Decision
      +Signals: []RiskSignal
    }
    enum Decision {
      ALLOW
      MFA_REQUIRED
      STEP_UP
      DENY
    }
    TrustScore --> Decision
    TrustScore *-- RiskSignal
  }

  package "trust::cases" {
    interface DeviceRepository {
      +IsKnownDevice(ctx, userID, fingerprintHash string) (bool, error)
      +SaveDevice(ctx, userID, fingerprintHash, uaHash string) error
    }
    interface IPReputation {
      +Lookup(ctx, ip string) (*IPInfo, error)
    }
    interface LoginHistoryRepository {
      +LastLogin(ctx, userID uuid.UUID) (*LoginRecord, error)
      +Save(ctx, record *LoginRecord) error
    }
    interface TrustCache {
      +GetLastContext(ctx, userID uuid.UUID) (*TrustContext, error)
      +SetLastContext(ctx, userID uuid.UUID, tc *TrustContext, ttl Duration) error
      +GetDeviceSet(ctx, userID uuid.UUID) ([]string, error)
      +AddDevice(ctx, userID uuid.UUID, hash string) error
      +GetFails(ctx, userID uuid.UUID) (int64, error)
      +IncrFails(ctx, userID uuid.UUID) (int64, error)
      +ResetFails(ctx, userID uuid.UUID) error
      +IncrIPFails(ctx, ipHash string) (int64, error)
    }
    class IPInfo {
      +Type: string
      +ASN: string
      +Country: string
      +IsTor: bool
      +IsDatacenter: bool
    }
    class LoginRecord {
      +UserID: uuid.UUID
      +IPHash: string
      +Country: string
      +ASN: string
      +Timestamp: time.Time
    }
    class EvaluateTrustInput {
      +UserID: uuid.UUID
      +Roles: []string
      +IP: string
      +UserAgent: string
      +Fingerprint: string
      +Timestamp: time.Time
      +Register: bool
    }
    class AnonymousCheckResult {
      +Decision: string
      +Reason: string
    }
    class EvaluateTrustCase {
      -devices: DeviceRepository
      -loginHistory: LoginHistoryRepository
      -cache: TrustCache
      -ipRep: IPReputation
      -salt: string
      +Execute(ctx, in EvaluateTrustInput) (*TrustScore, error)
    }
    class AnonymousCheckCase {
      -ipRep: IPReputation
      -cache: TrustCache
      -salt: string
      +Execute(ctx, ip, userAgent, fingerprint string) (*AnonymousCheckResult, error)
    }
    class "trust::Cases" as TrustCases {
      -anonCheck: *AnonymousCheckCase
      -evalTrust: *EvaluateTrustCase
      -trustCache: TrustCache
      +AnonymousCheck(ctx, ip, userAgent, fingerprint string) (*AnonymousCheckResult, error)
      +Evaluate(ctx, in EvaluateTrustInput) (*TrustScore, error)
      +IncrFails(ctx, userID uuid.UUID) (int64, error)
      +ResetFails(ctx, userID uuid.UUID) error
    }
  }

  package "trust::transport" {
    interface "trust::UseCases" as TrustUseCases {
      +AnonymousCheck(ctx, ip, userAgent, fingerprint string) (*AnonymousCheckResult, error)
      +Evaluate(ctx, in EvaluateTrustInput) (*TrustScore, error)
      +IncrFails(ctx, userID uuid.UUID) (int64, error)
      +ResetFails(ctx, userID uuid.UUID) error
    }
    class "trust::Handler" as TrustHandler {
      -log: *slog.Logger
      -cases: UseCases
      +Register(mux *http.ServeMux)
    }
  }

  package "trust::adapter/postgres" {
    class WorkingHoursRepo {
      -db: *pgxpool.Pool
      +Get(ctx, userID uuid.UUID) (start, end int, error)
    }
    class DeviceRepo {
      -db: *pgxpool.Pool
      +IsKnownDevice(ctx, userID, fingerprintHash string) (bool, error)
      +SaveDevice(ctx, userID, fingerprintHash, uaHash string) error
    }
    class LoginHistoryRepo {
      -db: *pgxpool.Pool
      +LastLogin(ctx, userID uuid.UUID) (*LoginRecord, error)
      +Save(ctx, record *LoginRecord) error
    }
  }

  package "trust::adapter/redis" {
    class "tr::TrustCache" as TrRedisCache {
      -client: *rdb.Client
      +GetLastContext(ctx, userID uuid.UUID) (*TrustContext, error)
      +SetLastContext(ctx, ...) error
      +GetDeviceSet(ctx, userID uuid.UUID) ([]string, error)
      +AddDevice(ctx, userID uuid.UUID, hash string) error
      +GetFails(ctx, userID uuid.UUID) (int64, error)
      +IncrFails(ctx, userID uuid.UUID) (int64, error)
      +ResetFails(ctx, userID uuid.UUID) error
      +IncrIPFails(ctx, ipHash string) (int64, error)
    }
    class IPRepCache {
      -client: *rdb.Client
      +Get(ctx, ipHash string) (*IPInfo, error)
      +Set(ctx, ipHash string, info *IPInfo, ttl Duration) error
    }
  }

  package "trust::adapter/http" {
    class IPReputationClient {
      -cache: ipCacheStore
      -httpClient: *http.Client
      -salt: string
      +Lookup(ctx, ip string) (*IPInfo, error)
    }
  }

  EvaluateTrustCase --> DeviceRepository
  EvaluateTrustCase --> LoginHistoryRepository
  EvaluateTrustCase --> TrustCache
  EvaluateTrustCase --> IPReputation
  AnonymousCheckCase --> IPReputation
  AnonymousCheckCase --> TrustCache
  TrustCases *-- AnonymousCheckCase
  TrustCases *-- EvaluateTrustCase
  TrustCases --> TrustCache
  TrustHandler --> TrustUseCases
  TrustCases ..|> TrustUseCases
  DeviceRepo ..|> DeviceRepository
  LoginHistoryRepo ..|> LoginHistoryRepository
  TrRedisCache ..|> TrustCache
  IPReputationClient ..|> IPReputation
  IPRepCache --> IPReputationClient
}

